<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Discord Clone</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --bg-primary: #313338;
            --bg-secondary: #2B2D31;
            --bg-tertiary: #1E1F22;
            --text-normal: #DBDEE1;
            --text-muted: #949BA4;
            --header-primary: #F2F3F5;
            --brand: #5865F2;
            --input-bg: #383A40;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-normal);
            font-family: 'Whitney', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* Server/Sidebar Styling */
        .sidebar {
            width: 72px;
            background-color: var(--bg-tertiary);
            padding: 12px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .server-icon {
            width: 48px;
            height: 48px;
            background-color: var(--bg-secondary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--brand);
            font-weight: bold;
            cursor: pointer;
            transition: border-radius 0.2s;
        }

        .server-icon:hover {
            border-radius: 30%;
            background-color: var(--brand);
            color: white;
        }

        .channel-list {
            width: 240px;
            background-color: var(--bg-secondary);
            padding: 12px 8px;
        }

        .channel-name {
            padding: 6px 8px;
            border-radius: 4px;
            color: var(--text-muted);
            cursor: pointer;
            font-weight: 500;
        }

        .channel-name.active {
            background-color: #3F4147;
            color: white;
        }

        /* Main Chat Area */
        .chat-container {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .chat-header {
            height: 48px;
            padding: 0 16px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid #26272D;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
            font-weight: bold;
            color: var(--header-primary);
        }

        .messages-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }

        .message {
            padding: 2px 16px;
            display: flex;
            gap: 16px;
        }

        .message:hover {
            background-color: #2E3035;
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: var(--brand);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
            margin-top: 4px;
        }

        .message-content {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 500;
            color: white;
            font-size: 1rem;
        }

        .timestamp {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-left: 8px;
        }

        .text {
            color: var(--text-normal);
            line-height: 1.375rem;
            white-space: pre-wrap;
        }

        /* Input Bar */
        .input-wrapper {
            padding: 0 16px 24px 16px;
        }

        .input-bar {
            background-color: var(--input-bg);
            border-radius: 8px;
            padding: 11px 16px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .input-bar input {
            background: transparent;
            border: none;
            color: var(--text-normal);
            width: 100%;
            outline: none;
        }

        .input-bar input::placeholder {
            color: #6D6F78;
        }
        
        .sender-input {
            width: 120px !important;
            border-right: 1px solid #4E5058 !important;
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="server-icon">D</div>
        <div class="server-icon" style="background-color: #35363C; color: #3BA55D;">+</div>
    </div>
    <div class="channel-list">
        <div style="font-size: 12px; font-weight: bold; color: var(--text-muted); margin-bottom: 8px; padding-left: 8px;">TEXT CHANNELS</div>
        <div class="channel-name active"># general</div>
        <div class="channel-name"># help</div>
        <div class="channel-name"># off-topic</div>
    </div>
    <div class="chat-container">
        <div class="chat-header">
            <span style="color: var(--text-muted); margin-right: 8px; font-size: 1.2rem;">#</span> general
        </div>
        <div class="messages-wrapper">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Auto scroll to bottom
        const wrapper = document.querySelector('.messages-wrapper');
        wrapper.scrollTop = wrapper.scrollHeight;
    </script>
</body>
</html>
